{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.saldeerscan.nl" }],
      "destination": "https://saldeerscan.nl/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/nieuws/cron",
      "schedule": "0 8 1,15 * *"
    },
    {
      "path": "/api/indexing/cron",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/webhooks/retry",
      "schedule": "0 6 * * *"
    }
  ]
}
