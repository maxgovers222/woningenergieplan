# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://jouw-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=jouw-anon-key
SUPABASE_SERVICE_ROLE_KEY=jouw-service-role-key

# Mapbox (server-side only — voor BAG/PDOK geocoding in lib/bag.ts)
MAPBOX_ACCESS_TOKEN=pk.jouw-mapbox-token

# AI
GOOGLE_AI_API_KEY=jouw-google-ai-key
ANTHROPIC_API_KEY=sk-ant-jouw-anthropic-key

# EP-online (RVO energie labels)
EPONLINE_API_KEY=jouw-eponline-key

# Google Analytics 4 (optioneel — Analytics component is stil als niet ingesteld)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Indexing API (service account JSON als enkele regel — voor kennisbank/nieuws/wijk pingen)
# GOOGLE_INDEXING_SA_KEY={"type":"service_account","client_email":"...","private_key":"...","token_uri":"https://oauth2.googleapis.com/token"}

# Resend (bevestigingsmail + PDF notificatie)
RESEND_API_KEY=re_jouw-resend-key
# Optioneel: overschrijf het from-adres (bijv. onboarding@resend.dev voor lokaal testen zonder geverifieerd domein)
# RESEND_FROM_EMAIL=SaldeerScan.nl <noreply@saldeerscan.nl>
